# Server

PORT=3000

HOST=0.0.0.0

HEALTH_POLL_INTERVAL_MS=30000

# Synthetic chatCompletion probe (real inference path). Default 180000 (3 min).
# Floor is 60000 (1 min) — lower values are clamped. Set 0/off/false to disable.
# HEALTH_SYNTHETIC_INTERVAL_MS=180000


# io.net Intelligence API (https://ai.io.net/ai/api-keys)

IONET_API_KEY=your_ionet_api_key_here

IONET_BASE_URL=https://api.intelligence.io.solutions/api/v1



# AkashML — optional Tier 2 DePIN fallback (https://akashml.com)

# AKASHML_API_KEY=akml-eKDFqXUhpBeBxSOKMZEwIgsLzvgOEwwJ

# AKASHML_BASE_URL=https://api.akashml.com/v1



# Nosana — optional Tier 3 DePIN fallback (per-deployment OpenAI-compatible endpoints)

# Nosana has no multi-model gateway: each deployed model gets its own
# https://<job-id>.node.k8s.prd.nos.ci/v1 URL. Deploy models in the Nosana
# dashboard, then map LMX aliases → those URLs. (Deployments API left for later.)

# NOSANA_API_KEY=nos_your_api_key_here

# NOSANA_ENDPOINTS={"llama-3-70b":"https://abc.node.k8s.prd.nos.ci/v1","deepseek-r1":{"baseUrl":"https://def.node.k8s.prd.nos.ci/v1","upstreamId":"DeepSeek-R1-Distill-Llama-70B-AWQ"}}



# Neon Postgres (recommended — keys + usage persist across restarts)
# Create a project at https://console.neon.tech and paste the pooled connection string:
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Legacy file storage (used when DATABASE_URL is unset)
# API_KEYS_FILE=/data/api-keys.json
# USAGE_FILE=/data/usage.json

# Demo key generation rate limit (per IP)
# Conservative default for free beta; increase after you understand real-world abuse patterns.
KEY_GEN_RATE_LIMIT_MAX=5
KEY_GEN_RATE_LIMIT_WINDOW_MS=3600000

# Chat completion rate limit (per API key)
# Conservative default for free beta; increase after you understand real-world abuse patterns.
CHAT_RATE_LIMIT_MAX=30
CHAT_RATE_LIMIT_WINDOW_MS=60000

# Brave Search API — web_search passthrough (https://brave.com/search/api/)
# Flat ~$5/1k requests on the Search plan; LMX charges WEB_SEARCH_PRICE_USDC per call.
# BRAVE_SEARCH_API_KEY=BSA...
# BRAVE_SEARCH_BASE_URL=https://api.search.brave.com/res/v1
# WEB_SEARCH_PRICE_USDC=0.01
# WEB_SEARCH_RATE_LIMIT_MAX=30
# WEB_SEARCH_RATE_LIMIT_WINDOW_MS=60000

# Internal credits (USD balance per API key)
INITIAL_CREDIT_BALANCE=1
MIN_CHAT_COST=0.00001
# Local dev: allow POST /v1/credits/topup from the demo UI
CREDITS_ALLOW_SELF_TOPUP=true

# Dashboard session tokens (email sign-in)
SESSION_SECRET=change-me-in-production
# SESSION_TTL_MS=2592000000

# Clerk — verify sign-in tokens from the web dashboard
# CLERK_SECRET_KEY=sk_test_your_key_here

# SIWE wallet auth (Base)
# SIWE_DOMAIN=lmxcloud.io
# SIWE_URI=https://lmxcloud.io
# SIWE_CHAIN_ID=8453

# USDC deposits on Base (requires DATABASE_URL)
# Prefer a dedicated RPC provider (Alchemy/CDP) over public endpoints for poller stability.
# Mainnet example: BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/your_key
# Sepolia example: BASE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/your_key
# TREASURY_ADDRESS=0xYourTreasuryWallet
# USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
# DEPOSIT_CONFIRMATIONS=10
# DEPOSIT_POLL_INTERVAL_MS=15000
# DEPOSIT_LOOKBACK_BLOCKS=100
# DEPOSIT_MAX_LOG_BLOCK_RANGE=2000
# DEPOSIT_MAX_USDC=10000

# Verifiable log anchoring on Base (requires DATABASE_URL)
# Deploy: pnpm deploy:anchor (with ANCHOR_PRIVATE_KEY, BASE_RPC_URL, SIWE_CHAIN_ID set)
# ANCHOR_CONTRACT_ADDRESS=0x51d2a68a5f43e44dff6cbf1b5231270a6fb4ca03
# ANCHOR_PRIVATE_KEY=f0ddea6ad69c774db5a12e74e28625dc728a3854edbf98a361b01199f72142b7
# ANCHOR_BATCH_INTERVAL_MS=300000
# ANCHOR_BATCH_MIN_EVENTS=1
# ANCHOR_BATCH_MAX_EVENTS=5000
# Verify: LOG_ID=<uuid> API_KEY=lmx_... pnpm verify:receipt

# x402 per-call payments (Sprint 2 — set X402_ENABLED=true to enable on chat)
# X402_ENABLED=false
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# CDP_API_KEY_ID=your_cdp_api_key_id
# CDP_API_KEY_SECRET=your_cdp_api_key_secret
# X402_MIN_CALL_USDC=0.001
# X402_DEFAULT_MAX_COMPLETION_TOKENS=1024
# X402_PRICING_MARGIN_PCT=0.25
# X402_RATE_LIMIT_MAX=10
# X402_RATE_LIMIT_WINDOW_MS=60000
# Optional explicit anonymous x402 limiter overrides (no API key callers)
# X402_ANON_RATE_LIMIT_MAX=10
# X402_ANON_RATE_LIMIT_WINDOW_MS=60000
# Also set these on the mcp-server Railway service for MCP pay-per-call:
#   X402_ENABLED, CDP_API_KEY_ID, CDP_API_KEY_SECRET, TREASURY_ADDRESS,
#   SIWE_CHAIN_ID (or X402_CHAIN_ID), LMX_X402_FULFILLMENT_API_KEY (or LMX_ADMIN_API_KEY)
# Test: pnpm test:x402  (402 probe) or PAYER_PRIVATE_KEY=0x... pnpm test:x402 -- --pay

# Sentry — optional error monitoring for the API
# SENTRY_DSN=https://examplePublicKey@example.ingest.sentry.io/123456

# Cloudflare origin lock (API + MCP HTTP)
# When set, rejects requests missing matching X-Origin-Secret header (403).
# Leave unset for local/dev. Set the same value on Railway + Cloudflare Transform Rule.
# /health (API) and /healthz (MCP) are exempt for Railway healthchecks.
# LMX_ORIGIN_SECRET=

# Together.ai — optional Tier 4 last-resort fallback (https://api.together.xyz)

# TOGETHER_API_KEY=your_together_api_key_here

# TOGETHER_BASE_URL=https://api.together.xyz/v1

# MCP server scaffold (`apps/mcp-server`)
# LMX_API_BASE_URL=http://127.0.0.1:3000
# LMX_ADMIN_API_KEY=lmx_service_key_for_smoke_tests_only
# LMX_DEFAULT_MODEL=llama-3-70b
# LMX_MCP_TRANSPORT=stdio
# LMX_MCP_HOST=0.0.0.0
# LMX_MCP_PORT=3334
# MCP_RATE_LIMIT_MAX=60
# MCP_RATE_LIMIT_WINDOW_MS=60000
# Same LMX_ORIGIN_SECRET as the API when hosting MCP over HTTP behind Cloudflare.
# LMX_ORIGIN_SECRET=
# For local stdio clients, users set LMX_API_KEY in .cursor/mcp.json env.
# For hosted HTTP clients, users set Authorization: Bearer lmx_... in mcp.json headers.


# Ops dashboard (`apps/ops`) — platform-wide visibility (not the customer console)
# Generate a long random secret (e.g. openssl rand -hex 32). Same value on API + MCP.
# LMX_OPS_API_KEY=
# Ops SPA: set VITE_API_URL to the API base; paste LMX_OPS_API_KEY in the UI (or localStorage).
# MCP forwards tool events to POST /v1/ops/mcp-events when LMX_OPS_API_KEY + LMX_API_BASE_URL are set.
# If Cloudflare origin lock is on, MCP also needs LMX_ORIGIN_SECRET to POST ingest.
