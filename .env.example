# Server

PORT=3000

HOST=0.0.0.0

HEALTH_POLL_INTERVAL_MS=30000



# io.net Intelligence API (https://ai.io.net/ai/api-keys)

IONET_API_KEY=your_ionet_api_key_here

IONET_BASE_URL=https://api.intelligence.io.solutions/api/v1



# AkashML — optional Tier 2 DePIN fallback (https://akashml.com)

# AKASHML_API_KEY=akml-eKDFqXUhpBeBxSOKMZEwIgsLzvgOEwwJ

# AKASHML_BASE_URL=https://api.akashml.com/v1



# Neon Postgres (recommended — keys + usage persist across restarts)
# Create a project at https://console.neon.tech and paste the pooled connection string:
# DATABASE_URL=postgresql://user:pass@host/neondb?sslmode=require

# Legacy file storage (used when DATABASE_URL is unset)
# API_KEYS_FILE=/data/api-keys.json
# USAGE_FILE=/data/usage.json

# Demo key generation rate limit (per IP)
# Conservative default for free beta; increase after you understand real-world abuse patterns.
KEY_GEN_RATE_LIMIT_MAX=5
KEY_GEN_RATE_LIMIT_WINDOW_MS=3600000

# Chat completion rate limit (per API key)
# Conservative default for free beta; increase after you understand real-world abuse patterns.
CHAT_RATE_LIMIT_MAX=30
CHAT_RATE_LIMIT_WINDOW_MS=60000

# Internal credits (USD balance per API key)
INITIAL_CREDIT_BALANCE=1
MIN_CHAT_COST=0.00001
# Local dev: allow POST /v1/credits/topup from the demo UI
CREDITS_ALLOW_SELF_TOPUP=true

# Dashboard session tokens (email sign-in)
SESSION_SECRET=change-me-in-production
# SESSION_TTL_MS=2592000000

# Clerk — verify sign-in tokens from the web dashboard
# CLERK_SECRET_KEY=sk_test_your_key_here

# Sentry — optional error monitoring for the API
# SENTRY_DSN=https://examplePublicKey@example.ingest.sentry.io/123456

# Together.ai — optional Tier 4 last-resort fallback (https://api.together.xyz)

# TOGETHER_API_KEY=your_together_api_key_here

# TOGETHER_BASE_URL=https://api.together.xyz/v1

