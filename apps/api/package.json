{
  "name": "@lmxcloud/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -b --force",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/**/*.test.ts",
    "test:x402": "tsx scripts/test-x402-chat.ts",
    "deploy:anchor": "node scripts/deploy-anchor.mjs",
    "verify:receipt": "tsx scripts/verify-receipt.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.10.0",
    "@coinbase/x402": "^2.1.0",
    "@fastify/cors": "^11.0.1",
    "@lmxcloud/shared": "workspace:*",
    "@openzeppelin/merkle-tree": "^1.0.8",
    "@sentry/node": "^10.63.0",
    "@x402/core": "^2.17.0",
    "@x402/evm": "^2.17.0",
    "@x402/fastify": "^2.17.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "pg": "^8.22.0",
    "siwe": "^3.0.0",
    "viem": "^2.54.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@types/pg": "^8.20.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
