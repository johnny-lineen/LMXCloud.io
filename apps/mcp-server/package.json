{
  "name": "@lmxcloud/mcp-server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:http": "cross-env LMX_MCP_TRANSPORT=http tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
