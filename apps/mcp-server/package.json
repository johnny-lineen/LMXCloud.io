    "@x402/core": "2.17.0",
    "@x402/extensions": "2.17.0",
    "@x402/mcp": "2.17.0",
    "dotenv": "^16.5.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "cross-env": "^10.1.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
